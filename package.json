{
  "name": "@aaroncql/pim-agent",
  "version": "0.0.1",
  "description": "Pim Agent is to Pi Agent what Vim is to Vi.",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "bin": {
    "pim": "./bin/pim.ts"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "pi": {
    "extensions": [
      "./src/extensions"
    ],
    "prompts": [
      "./src/prompts"
    ],
    "themes": [
      "./src/themes"
    ]
  },
  "scripts": {
    "dev": "bun link && pim",
    "typecheck": "tsgo --noEmit",
    "test": "bun test src --only-failures",
    "lint": "oxlint . --fix",
    "format": "prettier --write --list-different package.json tsconfig.json .oxlintrc.json .prettierrc.json \"src/**/*.ts\" \"bin/**/*.ts\" \"**/*.md\"",
    "check": "bun run typecheck && bun run test && bun run lint && bun run format"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260505.1",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "fzf": "^0.5.2",
    "grammy": "^1.42.0",
    "ignore": "^7.0.5",
    "ky": "^2.0.2"
  }
}
